# Application et base de donnees
DATABASE_URL="postgresql://meal_planner_user:meal_planner_password@localhost:5432/meal_planner_db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"

# Emails transactionnels
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASSWORD="replace-with-your-google-app-password"
EMAIL_FROM="Meal Planner <your-gmail-address@gmail.com>"

# Rate limiting distribue (requis en production, facultatif en local)
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-your-upstash-rest-token"
