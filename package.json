{
  "name": "meal-planner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "postinstall": "prisma generate",
    "vercel-build": "npm run build",
    "db:generate": "prisma generate",
    "db:up": "docker compose up -d",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-postgres.ps1",
    "db:restore:test": "powershell -ExecutionPolicy Bypass -File scripts/test-postgres-restore.ps1",
    "db:migrate:deploy": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:local": "npm run db:up && prisma migrate deploy && npm run test:e2e",
    "audit": "npm audit",
    "admin:promote": "node scripts/promote-admin.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "emailjs": "^4.0.3",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.15",
    "uuid": "11.1.1"
  }
}
